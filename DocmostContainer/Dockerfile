FROM docmost/docmost:latest

# This Dockerfile uses the official Docmost image as a base to allow
# self-hosting through GitHub Container Registry for improved stability
# and to ensure app store independence.

# The image is published as-is from the official source with no modifications.
# All configuration is handled through environment variables and volumes.

# Labels for GHCR
LABEL org.opencontainers.image.source="https://github.com/docmost/docmost"
LABEL org.opencontainers.image.description="Collaborative document management platform"
LABEL org.opencontainers.image.authors="JoshEvans-Weber"
LABEL org.opencontainers.image.url="https://docmost.com"
